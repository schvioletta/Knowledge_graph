# LLM (Yandex Alice / GigaChat) для NLP-пайплайна, метаданных и RAG-ответов.
# LLM_BACKEND=yandex|gigachat (по умолчанию gigachat). Модель Yandex — YANDEX_MODEL.
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=aliceai-llm-flash
LLM_BACKEND=yandex

# GigaChat (Sber) — альтернативный облачный бэкенд (backend/llm_client.py).
# GIGACHAT_API_KEY — авторизационный ключ (base64) из личного кабинета GigaChat.
# GIGACHAT_SCOPE: GIGACHAT_API_PERS (физлица) или GIGACHAT_API_CORP (юрлица).
GIGACHAT_API_KEY=
GIGACHAT_MODEL=GigaChat
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# YandexGPT — опционально для корпусной индексации (index_corpus.py).
# INDEX_USE_YANDEX=1 или флаг CLI --yandex; LLM_BACKEND=yandex — Yandex на все LLM-вызовы.
# Модель задаётся YANDEX_MODEL (на каждый запрос).
INDEX_USE_YANDEX=0

# LRU-кэш ответов LLM в памяти процесса (0 = выключить). Повторные одинаковые
# prompt+system не уходят в API повторно (NER, RAG-ответ, query expand).
LLM_CACHE_SIZE=512

# Query expansion: сначала облачный LLM (Yandex/GigaChat по LLM_BACKEND);
# при ошибке — fallback на локальный Qwen (Ollama).
QUERY_EXPAND_BASE_URL=http://localhost:11434/v1
QUERY_EXPAND_MODEL=qwen2.5:7b
QUERY_EXPAND_TIMEOUT_SEC=15
# QUERY_EXPAND_API_KEY=ollama

# NER (извлечение сущностей в RAG и NLP-пайплайне): локальный Qwen вместо GigaChat.
# NER_USE_OLLAMA=1 — включить; модель/URL по умолчанию из QUERY_EXPAND_* выше.
# При ошибке Ollama — fallback на GigaChat (если есть ключ).
NER_USE_OLLAMA=0
# NER_OLLAMA_MODEL=qwen2.5:7b
# NER_OLLAMA_BASE_URL=http://localhost:11434/v1
# NER_OLLAMA_TIMEOUT_SEC=120

# Персистентный кэш NER в rag_chunks[].ner (Neo4j): повторный RAG по тем же
# чанкам не вызывает LLM. При первом попадании чанка результат сохраняется
# автоматически. NER_PRECOMPUTE_ON_INDEX=1 — считать NER сразу при загрузке/
# активации документа. NER_CACHE_VERSION — bump при смене промпта/схемы.
NER_PRECOMPUTE_ON_INDEX=false
NER_CACHE_VERSION=1

# RAG — ускорение ответа (меньше LLM-вызовов на запрос):
# RAG_SKIP_QUERY_EXPAND=1   — без перефразировок (минус ~1 вызов Alice)
# RAG_SKIP_CHUNK_NER=1      — без NER по чанкам (минус ~6 вызовов; граф только публикации)
# EXTERNAL_SEARCH_ENABLED=false — без Google Scholar/Patents (минус до 12 с сети)

# Лексический буст поверх векторного поиска (backend/rag/lexical_boost.py):
# переранжирует найденные чанки, поднимая те, где есть точные числа/формулы/коды
# из запроса. WEIGHT=0 полностью отключает буст (останется чистый вектор).
RAG_LEXICAL_BOOST_WEIGHT=0.15
RAG_LEXICAL_POOL_MULT=4

# Подбор корпусных документов под запрос (backend/rag/store.py, activate_for_query):
# RAG_DISCOVERY_CHUNK_CAP — сколько чанков документа участвует в ОБНАРУЖЕНИИ (индекс
#   abstract_rag_chunks). Не-статьи индексируются целиком, поэтому без ограничения
#   один длинный документ выигрывал почти любой запрос при max-pooling (диагностика:
#   документ про электролит с 30 чанками всплывал везде). Ограничиваем первыми N.
# RAG_ACTIVATE_MIN_SCORE / RAG_ACTIVATE_TOP_RATIO — порог релевантности при активации:
#   активируем только документы со скором >= max(MIN_SCORE, TOP_RATIO * лучший_скор),
#   чтобы не подключать слабо релевантные (динамический отсев под силу запроса).
RAG_DISCOVERY_CHUNK_CAP=3
RAG_ACTIVATE_MIN_SCORE=0.35
RAG_ACTIVATE_TOP_RATIO=0.7

# Внешний поиск источников (backend/rag/external_search.py): по ключевым словам,
# извлечённым из вопроса и графа, ищет научные публикации в Google Scholar и
# патенты в Google Patents, дополняя ответ по внутренней базе. Любой сбой сети/
# капчи обрабатывается штатно как «не найдено» и не влияет на основной ответ.
# EXTERNAL_SEARCH_ENABLED=false полностью отключает внешний поиск.
EXTERNAL_SEARCH_ENABLED=true
EXTERNAL_SEARCH_TIMEOUT=12
EXTERNAL_SEARCH_MAX=5
# SERPAPI_KEY — если задан, Scholar/Patents идут через надёжный шлюз SerpAPI
# (иначе бесплатно и без ключа: Patents по XHR-JSON, Scholar по HTML — последний
# нестабилен из-за капчи Google, тогда просто вернётся «не найдено»).
# SERPAPI_KEY=

# Neo4j (см. docker-compose.yml + backend/graph_store_neo4j.py). NEO4J_PASSWORD
# должен совпадать с тем, что передан в `docker compose up -d neo4j`.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme12345

# networkx (по умолчанию, не требует Neo4j) или neo4j (см. backend/README.md).
GRAPH_BACKEND=networkx

# Путь к JSON-графу для GRAPH_BACKEND=networkx (по умолчанию data/sample_graph.json).
# GRAPH_DATA_PATH=data/real_graph.json
